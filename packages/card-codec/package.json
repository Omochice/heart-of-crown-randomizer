{
  "name": "@heart-of-crown-randomizer/card-codec",
  "version": "1.0.0",
  "description": "Bitfield-based encode/decode for card ID sets",
  "keywords": [
    "card",
    "codec",
    "heart-of-crown",
    "randomizer"
  ],
  "license": "Zlib",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "check": "npm-run-all2 check:*",
    "check:code": "biome check .",
    "check:fmt": "biome format .",
    "check:type": "tsc --noEmit",
    "clean": "rimraf dist",
    "fmt": "npm-run-all2 fmt:*",
    "fmt:biome": "npm-run-all2 fmt:biome:*",
    "fmt:biome:check": "biome check --write .",
    "fmt:biome:format": "biome format --write .",
    "fmt:package": "sort-package-json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "npm-run-all2": "catalog:",
    "rimraf": "catalog:",
    "sort-package-json": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
