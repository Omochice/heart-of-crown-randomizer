{
	"name": "@heart-of-crown-randomizer/site",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"build-storybook": "storybook build",
		"check": "npm-run-all2 check:*",
		"check:biome": "biome ci .",
		"check:knip": "knip",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"dev": "vite dev",
		"fmt": "npm-run-all2 fmt:*",
		"fmt:biome": "biome check --write --unsafe .",
		"fmt:package": "sort-package-json",
		"fmt:prettier": "prettier --write \"**/*.svelte\"",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"storybook": "storybook dev -p 6006",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"watch:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"dependencies": {
		"@heart-of-crown-randomizer/card": "workspace:*",
		"@heart-of-crown-randomizer/constraint": "workspace:*",
		"@heart-of-crown-randomizer/id-codec": "workspace:*",
		"@heart-of-crown-randomizer/randomizer": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@playwright/test": "1.60.0",
		"@storybook/addon-docs": "10.4.2",
		"@storybook/addon-svelte-csf": "5.1.2",
		"@storybook/svelte": "10.4.2",
		"@storybook/sveltekit": "10.4.2",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/kit": "2.63.0",
		"@sveltejs/mcp": "0.1.23",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.3.0",
		"@testing-library/svelte": "5.3.1",
		"@types/node": "24.13.1",
		"@vitest/browser-playwright": "4.1.8",
		"jsdom": "29.1.1",
		"knip": "catalog:",
		"lucide-svelte": "1.0.1",
		"npm-run-all2": "catalog:",
		"playwright": "1.60.0",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "4.1.0",
		"sort-package-json": "catalog:",
		"storybook": "10.4.2",
		"svelte": "5.56.2",
		"svelte-check": "4.6.0",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "catalog:"
	},
	"knip": {
		"ignoreDependencies": [
			"@sveltejs/mcp"
		]
	}
}
