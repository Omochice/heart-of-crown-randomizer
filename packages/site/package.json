{
	"name": "@heart-of-crown-randomizer/site",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"build-storybook": "storybook build",
		"check": "npm-run-all2 check:biome check:svelte",
		"check:biome": "biome ci .",
		"check:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"fmt": "npm-run-all2 fmt:*",
		"fmt:biome": "biome check --write --unsafe .",
		"fmt:package": "sort-package-json",
		"fmt:prettier": "prettier --write \"**/*.svelte\"",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"storybook": "storybook dev -p 6006",
		"test": "vitest run",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@heart-of-crown-randomizer/card": "workspace:*",
		"@heart-of-crown-randomizer/constraint": "workspace:*",
		"@heart-of-crown-randomizer/id-codec": "workspace:*",
		"@heart-of-crown-randomizer/randomizer": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@playwright/test": "1.59.1",
		"@storybook/addon-docs": "10.3.6",
		"@storybook/addon-interactions": "8.6.14",
		"@storybook/addon-svelte-csf": "5.1.2",
		"@storybook/svelte": "10.3.6",
		"@storybook/sveltekit": "10.3.6",
		"@storybook/test": "8.6.15",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/kit": "2.59.1",
		"@sveltejs/mcp": "0.1.22",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.2.4",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/svelte": "5.3.1",
		"@types/node": "24.12.3",
		"@vitest/browser": "4.1.5",
		"@vitest/browser-playwright": "4.1.5",
		"jsdom": "29.1.1",
		"lucide-svelte": "1.0.1",
		"npm-run-all2": "catalog:",
		"playwright": "1.59.1",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.1",
		"sort-package-json": "catalog:",
		"storybook": "10.3.6",
		"svelte": "5.55.5",
		"svelte-check": "4.4.8",
		"tailwindcss": "4.2.4",
		"typescript": "6.0.3",
		"vite": "8.0.11",
		"vitest": "catalog:"
	}
}
