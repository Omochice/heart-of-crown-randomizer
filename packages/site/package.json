{
	"name": "@heart-of-crown-randomizer/site",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"build-storybook": "storybook build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"dev": "vite dev",
		"fmt": "npm-run-all2 fmt:*",
		"fmt:package": "sort-package-json",
		"fmt:prettier": "prettier --write .",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"storybook": "storybook dev -p 6006",
		"test": "vitest run",
		"test:e2e": "playwright test"
	},
	"dependencies": {
		"@heart-of-crown-randomizer/card": "workspace:*",
		"@heart-of-crown-randomizer/randomizer": "workspace:*"
	},
	"devDependencies": {
		"@playwright/test": "1.58.2",
		"@storybook/addon-interactions": "8.6.14",
		"@storybook/addon-svelte-csf": "5.0.11",
		"@storybook/svelte": "10.2.17",
		"@storybook/sveltekit": "10.2.17",
		"@storybook/test": "8.6.15",
		"@sveltejs/adapter-auto": "7.0.1",
		"@sveltejs/kit": "2.54.0",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@tailwindcss/vite": "4.2.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/svelte": "5.3.1",
		"@types/node": "24.12.0",
		"jsdom": "28.1.0",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"sort-package-json": "catalog:",
		"storybook": "10.2.17",
		"svelte": "5.53.11",
		"svelte-check": "4.4.5",
		"tailwindcss": "4.2.1",
		"vite": "8.0.0"
	}
}
