{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "fmt": {},
    "clean": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["@heart-of-crown-randomizer/card#build"]
    },
    "check": {
      "dependsOn": ["@heart-of-crown-randomizer/card#build"]
    },
    "test": {},
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".svelte-kit/**"]
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    }
  }
}
